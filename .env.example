# ============================================================
# arr-stack-gluetun environment variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ----------------------------------------------------------
# VPN — WireGuard credentials
# Supports any WireGuard-based VPN provider (ProtonVPN, Mullvad, etc.)
# See docs/vpn-providers.md for provider-specific instructions
# ----------------------------------------------------------
WIREGUARD_PRIVATE_KEY=CHANGE_ME_BASE64_PRIVATE_KEY
WIREGUARD_PUBLIC_KEY=CHANGE_ME_BASE64_PUBLIC_KEY

# Tunnel IP assigned to you by your VPN provider
WIREGUARD_ADDRESSES=10.x.x.x/32

# VPN server endpoint
WIREGUARD_ENDPOINT_IP=CHANGE_ME_VPN_SERVER_IP
WIREGUARD_ENDPOINT_PORT=51820

# ----------------------------------------------------------
# Network
# Your LAN subnet — allows arr containers to still communicate
# with local services (torrent clients, NAS, etc.) over the VPN
# Examples: 192.168.1.0/24, 10.0.0.0/24, 192.168.4.0/22
# ----------------------------------------------------------
LAN_SUBNET=192.168.1.0/24

# ----------------------------------------------------------
# Paths — adjust to your system layout
# ----------------------------------------------------------

# Where container config data lives
APPDATA_PATH=/opt/appdata

# Root of your media library (movies, shows, etc.)
# Radarr and Sonarr see this as /data internally
MEDIA_PATH=/mnt/media

# Download directory for completed files
DOWNLOADS_PATH=/mnt/downloads

# ----------------------------------------------------------
# User/Group IDs
# Run: id $(whoami) to find your values
# Unraid users: PUID=99, PGID=100
# Most Linux users: PUID=1000, PGID=1000
# ----------------------------------------------------------
PUID=1000
PGID=1000

# ----------------------------------------------------------
# Timezone
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# ----------------------------------------------------------
TZ=America/Chicago
